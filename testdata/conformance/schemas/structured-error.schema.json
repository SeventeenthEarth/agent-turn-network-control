{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kkachi.local/conformance/structured-error.schema.json",
  "title": "ATN structured error response",
  "type": "object",
  "required": [
    "schema_version",
    "request_id",
    "ok",
    "error"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "const": false
    },
    "error": {
      "type": "object",
      "required": [
        "code",
        "category",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object"
        },
        "next": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
