{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kkachi.local/conformance/command-envelope.schema.json",
  "title": "KAN command envelope",
  "type": "object",
  "required": [
    "schema_version",
    "request_id",
    "command"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "params": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
