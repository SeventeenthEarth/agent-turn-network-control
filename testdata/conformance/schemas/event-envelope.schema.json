{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kkachi.local/conformance/event-envelope.schema.json",
  "title": "ATN event envelope",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "session_id",
    "session_type",
    "phase",
    "type",
    "from",
    "to",
    "created_at",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "command_id": {
      "type": "string"
    },
    "causation_event_id": {
      "type": "string"
    },
    "correlation_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "session_type": {
      "enum": [
        "delegation",
        "council"
      ]
    },
    "turn": {
      "type": "integer"
    },
    "phase": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "from": {
      "type": "string",
      "minLength": 1
    },
    "to": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "runner": {
      "type": "object"
    },
    "cost": {},
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
